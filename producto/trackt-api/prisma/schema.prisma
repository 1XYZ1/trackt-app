// Schema Prisma — Trackt
//
// Convenciones:
// - PKs con cuid() (sortable, sin extensions, equivalente funcional a UUID v7).
// - Nombres de tabla en snake_case via @@map; nombres de columna mapeados con @map.
// - tenant_id en todas las tablas de negocio (multi-tenant ready).
// - Timestamps automáticos: created_at + updated_at (excepto eventos/evidencias que solo created_at).
// - Campo metadata Json? en entidades core para extender sin migrations.
// - Indexes en columnas filtradas frecuentemente (tenant_id, estado, mecanico_id, ot_id).
// - FKs a auth.users (Supabase) son String UUID — Prisma no relaciona schemas distintos directamente.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =========================
// Enums
// =========================

enum OrdenTrabajoEstado {
  PENDIENTE
  EN_PROCESO
  CERRADA
  CANCELADA
}

enum TicketEstado {
  PENDIENTE
  ASIGNADO
  EN_EJECUCION
  EJECUTADO
  CERRADO
  CANCELADO
}

enum Prioridad {
  BAJA
  MEDIA
  ALTA
}

enum NotificacionTipo {
  TICKET_ASIGNADO
  TICKET_INICIADO
  TICKET_FINALIZADO
  TICKET_VALIDADO
  TICKET_RECHAZADO
  TICKET_CERRADO
  OT_CREADA
  OT_CERRADA
}

enum MovimientoInventarioTipo {
  ENTRADA
  SALIDA
  AJUSTE
  RESERVA
  LIBERACION
  CONSUMO
}

enum ReservaRepuestoEstado {
  SOLICITADA
  RESERVADA
  CONSUMIDA
  LIBERADA
  CANCELADA
}

enum EquipoEstadoOperativo {
  OPERATIVO
  EN_MANTENIMIENTO
  FUERA_DE_SERVICIO
}

// Ámbito de una marca dentro del catálogo: para equipos, repuestos o ambos.
enum MarcaTipo {
  EQUIPO
  REPUESTO
  AMBOS
}

// Ciclo de vida de una programación de mantenimiento:
// PROGRAMADA → GENERADA (se creó la OT, Fase 5) / CANCELADA.
// VENCIDA y COMPLETADA se setean en Fase 5 (job de vencimiento / cierre de OT).
enum ProgramacionMantenimientoEstado {
  PROGRAMADA
  GENERADA
  CANCELADA
  VENCIDA
  COMPLETADA
}

// =========================
// Modelos
// =========================

model Tenant {
  id        String   @id @default(cuid())
  nombre    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  equipos          Equipo[]
  ordenes          OrdenTrabajo[]
  tickets          Ticket[]
  notificaciones   Notificacion[]
  repuestos        Repuesto[]
  reservas         ReservaRepuesto[]
  movimientos      MovimientoInventario[]
  marcas           Marca[]
  equiposRepuestos EquipoRepuesto[]
  plantillas        PlantillaMantenimiento[]
  plantillasItems   PlantillaMantenimientoItem[]
  equiposPlantillas EquipoPlantillaMantenimiento[]
  programaciones    ProgramacionMantenimiento[]

  @@map("tenants")
}

model Equipo {
  id               String                @id @default(cuid())
  tenantId         String                @map("tenant_id")
  codigo           String
  nombre           String
  tipo             String?
  marca            String?
  modelo           String?
  numeroSerie      String?               @map("numero_serie")
  ubicacion        String?
  estadoOperativo  EquipoEstadoOperativo @default(OPERATIVO) @map("estado_operativo")
  fechaInstalacion DateTime?             @map("fecha_instalacion")
  fechaCompra      DateTime?             @map("fecha_compra")
  // Token estable para identificar el equipo vía QR. Se regenera bajo demanda
  // (invalidando el anterior). No se persiste imagen: el front renderiza el QR.
  qrToken          String?               @unique @map("qr_token")
  activo           Boolean               @default(true)
  metadata         Json?
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  tenant         Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ordenes        OrdenTrabajo[]
  repuestos      EquipoRepuesto[]
  plantillas     EquipoPlantillaMantenimiento[]
  programaciones ProgramacionMantenimiento[]

  @@unique([tenantId, codigo])
  @@index([tenantId])
  @@index([tenantId, activo])
  @@index([tenantId, estadoOperativo])
  @@map("equipos")
}

// Catálogo de marcas (datos maestros) para equipos y repuestos.
// Equipo.marca (texto libre) se mantiene por compatibilidad; la migración
// progresiva a marcaId se hará cuando el frontend consuma el catálogo.
model Marca {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  nombre    String
  tipo      MarcaTipo
  activo    Boolean   @default(true)
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  repuestos Repuesto[]

  @@unique([tenantId, nombre, tipo])
  @@index([tenantId, activo])
  @@map("marcas")
}

// Repuestos/insumos habituales de un equipo. Base para plantillas de
// mantenimiento y reservas asistidas (fases siguientes).
model EquipoRepuesto {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  equipoId    String   @map("equipo_id")
  repuestoId  String   @map("repuesto_id")
  cantidadRef Int?     @map("cantidad_ref") // cantidad de referencia por mantención
  observacion String?
  createdAt   DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  equipo   Equipo   @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  repuesto Repuesto @relation(fields: [repuestoId], references: [id], onDelete: Restrict)

  @@unique([tenantId, equipoId, repuestoId])
  @@index([tenantId, equipoId])
  @@index([repuestoId])
  @@map("equipos_repuestos")
}

// Plantilla de mantenimiento: "receta" reutilizable con checklist (en
// metadata.checklist como string[]) e insumos sugeridos. Base para
// programaciones, generación de OT/tickets y reservas (fases 4+).
model PlantillaMantenimiento {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  nombre      String
  descripcion String?
  tipoEquipo  String?  @map("tipo_equipo") // matchea Equipo.tipo (texto libre)
  frecuencia  String?  // texto libre ("mensual", "500 horas"); se formaliza en Fase 4
  activo      Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant         Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items          PlantillaMantenimientoItem[]
  equipos        EquipoPlantillaMantenimiento[]
  programaciones ProgramacionMantenimiento[]

  @@index([tenantId, activo])
  @@index([tenantId, tipoEquipo])
  @@map("plantillas_mantenimiento")
}

// Insumo sugerido de una plantilla. obligatorio=false marca insumos
// opcionales que la reserva (fase 5+) puede omitir.
model PlantillaMantenimientoItem {
  id          String  @id @default(cuid())
  tenantId    String  @map("tenant_id")
  plantillaId String  @map("plantilla_id")
  repuestoId  String  @map("repuesto_id")
  cantidad    Int // > 0 (CHECK en BD)
  obligatorio Boolean @default(true)
  observacion String?

  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plantilla PlantillaMantenimiento @relation(fields: [plantillaId], references: [id], onDelete: Cascade)
  repuesto  Repuesto               @relation(fields: [repuestoId], references: [id], onDelete: Restrict)

  @@unique([tenantId, plantillaId, repuestoId])
  @@index([tenantId, plantillaId])
  @@index([repuestoId])
  @@map("plantillas_mantenimiento_items")
}

// Asociación equipo ↔ plantilla: qué plantillas aplican a cada equipo.
model EquipoPlantillaMantenimiento {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  equipoId    String   @map("equipo_id")
  plantillaId String   @map("plantilla_id")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  equipo    Equipo                 @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  plantilla PlantillaMantenimiento @relation(fields: [plantillaId], references: [id], onDelete: Cascade)

  @@unique([tenantId, equipoId, plantillaId])
  @@index([tenantId, equipoId])
  @@index([plantillaId])
  @@map("equipos_plantillas_mantenimiento")
}

// Programación de mantenimiento: trabajo futuro planificado sobre un equipo,
// opcionalmente basado en una plantilla. En Fase 5 genera OT/tickets
// (estado GENERADA) y reserva insumos desde la plantilla.
model ProgramacionMantenimiento {
  id              String                          @id @default(cuid())
  tenantId        String                          @map("tenant_id")
  equipoId        String                          @map("equipo_id")
  plantillaId     String?                         @map("plantilla_id")
  titulo          String
  descripcion     String?
  fechaProgramada DateTime                        @map("fecha_programada")
  responsableId   String?                         @map("responsable_id") // auth.users.id
  prioridad       Prioridad                       @default(MEDIA)
  estado          ProgramacionMantenimientoEstado @default(PROGRAMADA)
  recurrencia     String? // texto libre ("mensual", "cada 500 horas"); se materializa al generar OT (Fase 5)
  metadata        Json?
  createdAt       DateTime                        @default(now()) @map("created_at")
  updatedAt       DateTime                        @updatedAt @map("updated_at")

  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  equipo    Equipo                  @relation(fields: [equipoId], references: [id])
  plantilla PlantillaMantenimiento? @relation(fields: [plantillaId], references: [id], onDelete: SetNull)

  @@index([tenantId, fechaProgramada])
  @@index([tenantId, equipoId])
  @@index([tenantId, estado])
  @@index([plantillaId])
  @@map("programaciones_mantenimiento")
}

model OrdenTrabajo {
  id          String             @id @default(cuid())
  tenantId    String             @map("tenant_id")
  codigo      String
  equipoId    String             @map("equipo_id")
  descripcion String
  prioridad   Prioridad          @default(MEDIA)
  estado      OrdenTrabajoEstado @default(PENDIENTE)
  creadoPorId String             @map("creado_por_id") // auth.users.id
  metadata    Json?
  fechaCierre DateTime?          @map("fecha_cierre")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  equipo  Equipo   @relation(fields: [equipoId], references: [id])
  tickets Ticket[]

  @@unique([tenantId, codigo])
  @@index([tenantId, estado])
  @@index([equipoId])
  @@map("ordenes_trabajo")
}

model Ticket {
  id          String       @id @default(cuid())
  tenantId    String       @map("tenant_id")
  otId        String       @map("ot_id")
  codigo      String
  titulo      String
  descripcion String
  estado      TicketEstado @default(PENDIENTE)
  prioridad   Prioridad    @default(MEDIA)
  mecanicoId  String?      @map("mecanico_id") // auth.users.id
  jefeId      String?      @map("jefe_id") // auth.users.id (creador / asignador)
  metadata    Json?

  fechaAsignacion      DateTime? @map("fecha_asignacion")
  fechaInicioEjecucion DateTime? @map("fecha_inicio_ejecucion")
  fechaFinEjecucion    DateTime? @map("fecha_fin_ejecucion")
  fechaValidacion      DateTime? @map("fecha_validacion")
  fechaCierre          DateTime? @map("fecha_cierre")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ot          OrdenTrabajo           @relation(fields: [otId], references: [id], onDelete: Cascade)
  eventos     EventoEstadoTicket[]
  evidencias  Evidencia[]
  reservas    ReservaRepuesto[]
  movimientos MovimientoInventario[]

  @@unique([tenantId, codigo])
  @@index([tenantId, estado])
  @@index([otId])
  @@index([mecanicoId])
  @@map("tickets")
}

model EventoEstadoTicket {
  id             String        @id @default(cuid())
  ticketId       String        @map("ticket_id")
  estadoAnterior TicketEstado? @map("estado_anterior")
  estadoNuevo    TicketEstado  @map("estado_nuevo")
  usuarioId      String        @map("usuario_id") // auth.users.id
  observacion    String?
  metadata       Json?
  createdAt      DateTime      @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@map("eventos_estado_ticket")
}

model Evidencia {
  id          String   @id @default(cuid())
  ticketId    String   @map("ticket_id")
  storagePath String   @map("storage_path")
  descripcion String?
  subidoPorId String   @map("subido_por_id") // auth.users.id
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("evidencias")
}

model Notificacion {
  id        String           @id @default(cuid())
  tenantId  String           @map("tenant_id")
  usuarioId String           @map("usuario_id") // auth.users.id
  tipo      NotificacionTipo
  payload   Json             @default("{}")
  leida     Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([usuarioId, leida])
  @@index([tenantId])
  @@map("notificaciones")
}

// =========================
// Inventario (repuestos / reservas / movimientos)
// =========================

model Repuesto {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  codigo           String
  nombre           String
  descripcion      String?
  categoria        String?
  unidad           String   @default("unidad")
  stockMinimo      Int      @default(0) @map("stock_minimo")
  marcaId          String?  @map("marca_id")
  codigoFabricante String?  @map("codigo_fabricante")
  ubicacionBodega  String?  @map("ubicacion_bodega")
  proveedor        String?
  activo           Boolean  @default(true)
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant          Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  marca           Marca?                       @relation(fields: [marcaId], references: [id], onDelete: SetNull)
  stock           InventarioStock?
  items           ReservaRepuestoItem[]
  movimientos     MovimientoInventario[]
  equipos         EquipoRepuesto[]
  plantillasItems PlantillaMantenimientoItem[]

  @@unique([tenantId, codigo])
  @@index([tenantId, activo])
  @@index([marcaId])
  @@map("repuestos")
}

model InventarioStock {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  repuestoId     String   @unique @map("repuesto_id")
  stockActual    Int      @default(0) @map("stock_actual")
  stockReservado Int      @default(0) @map("stock_reservado")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  repuesto Repuesto @relation(fields: [repuestoId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("inventario_stock")
}

model ReservaRepuesto {
  id            String               @id @default(cuid())
  tenantId      String               @map("tenant_id")
  ticketId      String               @map("ticket_id")
  estado        ReservaRepuestoEstado @default(RESERVADA)
  creadoPorId   String               @map("creado_por_id") // auth.users.id
  aprobadoPorId String?              @map("aprobado_por_id") // auth.users.id
  observacion   String?
  metadata      Json?
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticket      Ticket                 @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  items       ReservaRepuestoItem[]
  movimientos MovimientoInventario[]

  @@index([tenantId, ticketId])
  @@index([tenantId, estado])
  @@map("reservas_repuestos")
}

model ReservaRepuestoItem {
  id         String @id @default(cuid())
  reservaId  String @map("reserva_id")
  repuestoId String @map("repuesto_id")
  cantidad   Int

  reserva  ReservaRepuesto @relation(fields: [reservaId], references: [id], onDelete: Cascade)
  repuesto Repuesto        @relation(fields: [repuestoId], references: [id], onDelete: Restrict)

  @@index([reservaId])
  @@index([repuestoId])
  @@map("reserva_repuesto_items")
}

model MovimientoInventario {
  id               String                   @id @default(cuid())
  tenantId         String                   @map("tenant_id")
  repuestoId       String                   @map("repuesto_id")
  tipo             MovimientoInventarioTipo
  cantidad         Int // positivo o negativo; el signo describe el efecto sobre stockActual o stockReservado
  stockResultante  Int                      @map("stock_resultante") // snapshot post-movimiento de stockActual
  usuarioId        String                   @map("usuario_id") // auth.users.id
  ticketId         String?                  @map("ticket_id")
  reservaId        String?                  @map("reserva_id")
  observacion      String?
  metadata         Json?
  createdAt        DateTime                 @default(now()) @map("created_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  repuesto Repuesto         @relation(fields: [repuestoId], references: [id], onDelete: Cascade)
  ticket   Ticket?          @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  reserva  ReservaRepuesto? @relation(fields: [reservaId], references: [id], onDelete: SetNull)

  @@index([tenantId, repuestoId, createdAt])
  @@index([reservaId])
  @@index([ticketId])
  @@map("movimientos_inventario")
}
